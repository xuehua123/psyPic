APP_URL=http://localhost:3000
PSYPIC_INSECURE_COOKIES=false
DATABASE_URL=postgresql://psypic:psypic@localhost:5432/psypic
REDIS_URL=redis://localhost:6379
# Production secrets must be high-entropy, different values.
SESSION_SECRET=replace-with-session-secret
KEY_ENCRYPTION_SECRET=replace-with-different-key-encryption-secret
SUB2API_DEFAULT_BASE_URL=https://sub2api.example.com/v1
SUB2API_TIMEOUT_MS=300000
MAX_IMAGE_UPLOAD_MB=20
PSYPIC_MAX_IMAGE_N=4
PSYPIC_MAX_UPLOAD_MB=20
PSYPIC_MAX_SIZE_TIER=2K
PSYPIC_ALLOW_MODERATION_LOW=false
PSYPIC_COMMUNITY_ENABLED=true
PSYPIC_PUBLIC_PUBLISH_ENABLED=true
PSYPIC_STREAM_ENABLED=true
PSYPIC_MAX_ACTIVE_IMAGE_TASKS_PER_USER=1
PSYPIC_RUNTIME_SETTINGS_STORE=file
PSYPIC_RUNTIME_SETTINGS_FILE=runtime-settings.json
PSYPIC_AUDIT_LOG_STORE=file
PSYPIC_AUDIT_LOG_FILE=audit-logs.json
PSYPIC_AUTH_STORE=database
PSYPIC_IMAGE_TASK_STORE=database
PSYPIC_JOB_RUNTIME_EVENT_STORE=database
PSYPIC_COMMUNITY_STORE=database
# Phase B 工作台数据服务端化（plan slug 2026-05-06-workbench-server-sync）
# database = API 走 Prisma + IndexedDB 仅作 offline cache（默认）
# indexeddb = API 路由返回 503，前端完全 fallback 本地（V1.0 兼容 / migration 失败时运维侧一键回退）
PSYPIC_WORKBENCH_PROJECTS_STORE=database
PSYPIC_BOARD_DOCUMENTS_STORE=indexeddb
PSYPIC_SEARCH_INDEX_ENABLED=false
TEMP_ASSET_TTL_HOURS=72
# local is for development only; production should use r2, s3, or minio.
ASSET_STORAGE_DRIVER=local
ASSET_STORAGE_ENDPOINT=
ASSET_STORAGE_REGION=auto
ASSET_STORAGE_BUCKET=
ASSET_STORAGE_PREFIX=psypic/
ASSET_STORAGE_ACCESS_KEY_ID=
ASSET_STORAGE_SECRET_ACCESS_KEY=
ASSET_STORAGE_FORCE_PATH_STYLE=false
