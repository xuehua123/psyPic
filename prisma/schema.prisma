generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

enum KeyBindingStatus {
  active
  disabled
  expired
}

enum ImageTaskType {
  generation
  edit
}

enum ImageTaskStatus {
  queued
  running
  succeeded
  failed
  canceled
}

enum CommunityWorkVisibility {
  private
  unlisted
  public
}

enum CommunityWorkReviewStatus {
  pending
  approved
  rejected
  taken_down
}

model User {
  id            String       @id
  sub2apiUserId String?      @map("sub2api_user_id")
  displayName   String?      @map("display_name")
  avatarUrl     String?      @map("avatar_url")
  role          UserRole     @default(user)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  sessions      Session[]
  keyBindings   KeyBinding[]
  auditLogs     AuditLog[]
  imageTasks    ImageTask[]
  imageAssets   ImageAsset[]
  imageAssetTags ImageAssetTag[]
  albums        Album[]
  communityWorks CommunityWork[]

  @@map("users")
}

model Session {
  id           String     @id
  userId       String     @map("user_id")
  keyBindingId String?    @map("key_binding_id")
  expiresAt    DateTime   @map("expires_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  lastSeenAt   DateTime   @default(now()) @map("last_seen_at")
  revokedAt    DateTime?  @map("revoked_at")
  user         User       @relation(fields: [userId], references: [id])
  keyBinding   KeyBinding? @relation(fields: [keyBindingId], references: [id])

  @@index([userId])
  @@index([keyBindingId])
  @@index([expiresAt])
  @@map("sessions")
}

model KeyBinding {
  id                         String             @id
  userId                     String             @map("user_id")
  sub2apiBaseUrl             String             @map("sub2api_base_url")
  sub2apiApiKeyCiphertext    String?            @map("sub2api_api_key_ciphertext")
  sub2apiApiKeyId            String?            @map("sub2api_api_key_id")
  defaultModel               String             @default("gpt-image-2") @map("default_model")
  enabledModels              Json               @map("enabled_models")
  limits                     Json
  status                     KeyBindingStatus   @default(active)
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")
  user                       User               @relation(fields: [userId], references: [id])
  sessions                   Session[]
  imageTasks                 ImageTask[]

  @@index([userId])
  @@index([status])
  @@map("key_bindings")
}

model AuditLog {
  id            String   @id
  actorUserId   String?  @map("actor_user_id")
  action        String
  targetType    String   @map("target_type")
  targetId      String   @map("target_id")
  requestId     String   @map("request_id")
  ipHash        String?  @map("ip_hash")
  userAgentHash String?  @map("user_agent_hash")
  metadata      Json
  createdAt     DateTime @default(now()) @map("created_at")
  actor         User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([requestId])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model ImageTask {
  id                String           @id
  userId            String           @map("user_id")
  keyBindingId      String?          @map("key_binding_id")
  type              ImageTaskType
  status            ImageTaskStatus
  prompt            String
  params            Json
  usage             Json?
  upstreamRequestId String?          @map("upstream_request_id")
  errorCode         String?          @map("error_code")
  errorMessage      String?          @map("error_message")
  durationMs        Int?             @map("duration_ms")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  user              User             @relation(fields: [userId], references: [id])
  keyBinding        KeyBinding?      @relation(fields: [keyBindingId], references: [id])
  assets            ImageAsset[]
  communityWorks    CommunityWork[]

  @@index([userId, createdAt])
  @@index([keyBindingId])
  @@index([status])
  @@map("image_tasks")
}

model ImageAsset {
  id          String          @id
  userId      String          @map("user_id")
  taskId      String?         @map("task_id")
  storageKey  String?         @map("storage_key")
  mimeType    String?         @map("mime_type")
  format      String
  width       Int?
  height      Int?
  sizeBytes   Int?            @map("size_bytes")
  favorite    Boolean         @default(false)
  metadata    Json?
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  user        User            @relation(fields: [userId], references: [id])
  task        ImageTask?      @relation(fields: [taskId], references: [id])
  tags        ImageAssetTag[]
  albumItems  AlbumItem[]
  communityWorks CommunityWork[]

  @@index([userId, createdAt])
  @@index([taskId])
  @@index([favorite])
  @@index([deletedAt])
  @@map("image_assets")
}

model ImageAssetTag {
  id        String     @id
  userId    String     @map("user_id")
  assetId   String     @map("asset_id")
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  user      User       @relation(fields: [userId], references: [id])
  asset     ImageAsset @relation(fields: [assetId], references: [id])

  @@unique([assetId, name])
  @@index([userId, name])
  @@map("image_asset_tags")
}

model Album {
  id           String      @id
  userId       String      @map("user_id")
  title        String
  description  String?
  coverAssetId String?     @map("cover_asset_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  user         User        @relation(fields: [userId], references: [id])
  items        AlbumItem[]

  @@index([userId, createdAt])
  @@map("albums")
}

model AlbumItem {
  id        String     @id
  albumId   String     @map("album_id")
  assetId   String     @map("asset_id")
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  album     Album      @relation(fields: [albumId], references: [id])
  asset     ImageAsset @relation(fields: [assetId], references: [id])

  @@unique([albumId, assetId])
  @@index([assetId])
  @@map("album_items")
}

model CommunityWork {
  id                      String                    @id
  userId                  String                    @map("user_id")
  taskId                  String                    @map("task_id")
  assetId                 String                    @map("asset_id")
  visibility              CommunityWorkVisibility   @default(private)
  reviewStatus            CommunityWorkReviewStatus @default(approved) @map("review_status")
  title                   String
  scene                   String?
  tags                    String[]
  promptSnapshot          String                    @map("prompt_snapshot")
  paramsSnapshot          Json                      @map("params_snapshot")
  disclosePrompt          Boolean                   @default(false) @map("disclose_prompt")
  discloseParams          Boolean                   @default(false) @map("disclose_params")
  discloseReferenceImages Boolean                   @default(false) @map("disclose_reference_images")
  allowSameGeneration     Boolean                   @default(false) @map("allow_same_generation")
  allowReferenceReuse     Boolean                   @default(false) @map("allow_reference_reuse")
  publishedAt             DateTime?                 @map("published_at")
  takenDownAt             DateTime?                 @map("taken_down_at")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  user                    User                      @relation(fields: [userId], references: [id])
  task                    ImageTask                 @relation(fields: [taskId], references: [id])
  asset                   ImageAsset                @relation(fields: [assetId], references: [id])

  @@index([userId, createdAt])
  @@index([assetId])
  @@index([visibility, reviewStatus, createdAt])
  @@map("community_works")
}
