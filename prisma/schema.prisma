generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
}

enum KeyBindingStatus {
  active
  disabled
  expired
}

enum ImageTaskType {
  generation
  edit
}

enum ImageTaskStatus {
  queued
  running
  succeeded
  failed
  canceled
  timed_out
}

enum CommunityWorkVisibility {
  private
  unlisted
  public
}

enum CommunityWorkReviewStatus {
  pending
  approved
  rejected
  taken_down
}

enum CommunityReportStatus {
  open
  reviewed
  dismissed
}

enum VersionNodeStatus {
  queued
  running
  succeeded
  failed
  canceled
  timed_out
  partial_image
}

model User {
  id                       String                  @id
  email                    String?
  emailNormalized          String?                 @unique @map("email_normalized")
  emailVerifiedAt          DateTime?               @map("email_verified_at")
  passwordHash             String?                 @map("password_hash")
  passwordSalt             String?                 @map("password_salt")
  status                   UserStatus              @default(active)
  lastLoginAt              DateTime?               @map("last_login_at")
  sub2apiUserId            String?                 @map("sub2api_user_id")
  displayName              String?                 @map("display_name")
  avatarUrl                String?                 @map("avatar_url")
  role                     UserRole                @default(user)
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")
  sessions                 Session[]
  keyBindings              KeyBinding[]
  auditLogs                AuditLog[]
  imageTasks               ImageTask[]
  imageBatches             ImageBatch[]
  imageAssets              ImageAsset[]
  imageAssetTags           ImageAssetTag[]
  albums                   Album[]
  communityWorks           CommunityWork[]
  communityReports         CommunityReport[]       @relation("CommunityReportsMade")
  reviewedCommunityReports CommunityReport[]       @relation("CommunityReportsReviewed")
  runtimeSettingsUpdated   RuntimeSetting[]        @relation("RuntimeSettingsUpdatedBy")
  communityWorkLikes       CommunityWorkLike[]
  communityWorkFavorites   CommunityWorkFavorite[]
  workbenchProjects        WorkbenchProject[]
  workbenchSyncMutations   WorkbenchSyncMutation[]

  @@map("users")
}

model Session {
  id           String      @id
  userId       String      @map("user_id")
  keyBindingId String?     @map("key_binding_id")
  expiresAt    DateTime    @map("expires_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  lastSeenAt   DateTime    @default(now()) @map("last_seen_at")
  revokedAt    DateTime?   @map("revoked_at")
  user         User        @relation(fields: [userId], references: [id])
  keyBinding   KeyBinding? @relation(fields: [keyBindingId], references: [id])

  @@index([userId])
  @@index([keyBindingId])
  @@index([expiresAt])
  @@map("sessions")
}

model KeyBinding {
  id                      String           @id
  userId                  String           @map("user_id")
  sub2apiBaseUrl          String           @map("sub2api_base_url")
  sub2apiApiKeyCiphertext String?          @map("sub2api_api_key_ciphertext")
  sub2apiApiKeyId         String?          @map("sub2api_api_key_id")
  defaultModel            String           @default("gpt-image-2") @map("default_model")
  enabledModels           Json             @map("enabled_models")
  limits                  Json
  status                  KeyBindingStatus @default(active)
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")
  user                    User             @relation(fields: [userId], references: [id])
  sessions                Session[]
  imageTasks              ImageTask[]

  @@index([userId])
  @@index([status])
  @@map("key_bindings")
}

model AuditLog {
  id            String   @id
  actorUserId   String?  @map("actor_user_id")
  action        String
  targetType    String   @map("target_type")
  targetId      String   @map("target_id")
  requestId     String   @map("request_id")
  ipHash        String?  @map("ip_hash")
  userAgentHash String?  @map("user_agent_hash")
  metadata      Json
  createdAt     DateTime @default(now()) @map("created_at")
  actor         User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([requestId])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model RuntimeSetting {
  key             String   @id
  value           Json
  updatedByUserId String?  @map("updated_by_user_id")
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedBy       User?    @relation("RuntimeSettingsUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([updatedByUserId])
  @@map("runtime_settings")
}

model ImageTask {
  id                String            @id
  userId            String            @map("user_id")
  keyBindingId      String?           @map("key_binding_id")
  type              ImageTaskType
  status            ImageTaskStatus
  prompt            String
  params            Json
  usage             Json?
  upstreamRequestId String?           @map("upstream_request_id")
  errorCode         String?           @map("error_code")
  errorMessage      String?           @map("error_message")
  durationMs        Int?              @map("duration_ms")
  projectId         String?           @map("project_id")
  sessionId         String?           @map("session_id")
  versionNodeId     String?           @unique @map("version_node_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  user              User              @relation(fields: [userId], references: [id])
  keyBinding        KeyBinding?       @relation(fields: [keyBindingId], references: [id])
  project           WorkbenchProject? @relation(fields: [projectId], references: [id])
  session           CreativeSession?  @relation(fields: [sessionId], references: [id])
  versionNode       VersionNode?      @relation("VersionNodeTask", fields: [versionNodeId], references: [id])
  assets            ImageAsset[]
  communityWorks    CommunityWork[]
  batchItems        ImageBatchItem[]

  @@index([userId, createdAt])
  @@index([keyBindingId])
  @@index([status])
  @@index([projectId, createdAt])
  @@index([sessionId, createdAt])
  @@map("image_tasks")
}

model ImageBatch {
  id        String           @id
  userId    String           @map("user_id")
  status    String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id])
  items     ImageBatchItem[]

  @@index([userId, createdAt])
  @@index([status])
  @@map("image_batches")
}

model ImageBatchItem {
  id           String          @id
  batchId      String          @map("batch_id")
  taskId       String          @map("task_id")
  prompt       String
  params       Json
  size         String
  status       ImageTaskStatus
  queueStatus  String          @map("queue_status")
  retryCount   Int             @default(0) @map("retry_count")
  errorCode    String?         @map("error_code")
  errorMessage String?         @map("error_message")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  batch        ImageBatch      @relation(fields: [batchId], references: [id])
  task         ImageTask       @relation(fields: [taskId], references: [id])

  @@index([batchId, status])
  @@index([taskId])
  @@map("image_batch_items")
}

model ImageAsset {
  id             String          @id
  userId         String          @map("user_id")
  taskId         String?         @map("task_id")
  storageKey     String?         @map("storage_key")
  mimeType       String?         @map("mime_type")
  format         String
  width          Int?
  height         Int?
  sizeBytes      Int?            @map("size_bytes")
  favorite       Boolean         @default(false)
  metadata       Json?
  deletedAt      DateTime?       @map("deleted_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  user           User            @relation(fields: [userId], references: [id])
  task           ImageTask?      @relation(fields: [taskId], references: [id])
  tags           ImageAssetTag[]
  albumItems     AlbumItem[]
  communityWorks CommunityWork[]

  @@index([userId, createdAt])
  @@index([taskId])
  @@index([favorite])
  @@index([deletedAt])
  @@map("image_assets")
}

model ImageAssetTag {
  id        String     @id
  userId    String     @map("user_id")
  assetId   String     @map("asset_id")
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  user      User       @relation(fields: [userId], references: [id])
  asset     ImageAsset @relation(fields: [assetId], references: [id])

  @@unique([assetId, name])
  @@index([userId, name])
  @@map("image_asset_tags")
}

model Album {
  id           String      @id
  userId       String      @map("user_id")
  title        String
  description  String?
  coverAssetId String?     @map("cover_asset_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  user         User        @relation(fields: [userId], references: [id])
  items        AlbumItem[]

  @@index([userId, createdAt])
  @@map("albums")
}

model AlbumItem {
  id        String     @id
  albumId   String     @map("album_id")
  assetId   String     @map("asset_id")
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  album     Album      @relation(fields: [albumId], references: [id])
  asset     ImageAsset @relation(fields: [assetId], references: [id])

  @@unique([albumId, assetId])
  @@index([assetId])
  @@map("album_items")
}

model CommunityWork {
  id                      String                    @id
  userId                  String                    @map("user_id")
  taskId                  String                    @map("task_id")
  assetId                 String                    @map("asset_id")
  visibility              CommunityWorkVisibility   @default(private)
  reviewStatus            CommunityWorkReviewStatus @default(approved) @map("review_status")
  title                   String
  scene                   String?
  tags                    String[]
  promptSnapshot          String                    @map("prompt_snapshot")
  paramsSnapshot          Json                      @map("params_snapshot")
  disclosePrompt          Boolean                   @default(false) @map("disclose_prompt")
  discloseParams          Boolean                   @default(false) @map("disclose_params")
  discloseReferenceImages Boolean                   @default(false) @map("disclose_reference_images")
  allowSameGeneration     Boolean                   @default(false) @map("allow_same_generation")
  allowReferenceReuse     Boolean                   @default(false) @map("allow_reference_reuse")
  publishedAt             DateTime?                 @map("published_at")
  takenDownAt             DateTime?                 @map("taken_down_at")
  featuredAt              DateTime?                 @map("featured_at")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  user                    User                      @relation(fields: [userId], references: [id])
  task                    ImageTask                 @relation(fields: [taskId], references: [id])
  asset                   ImageAsset                @relation(fields: [assetId], references: [id])
  reports                 CommunityReport[]
  likes                   CommunityWorkLike[]
  favorites               CommunityWorkFavorite[]

  @@index([userId, createdAt])
  @@index([assetId])
  @@index([visibility, reviewStatus, createdAt])
  @@index([visibility, reviewStatus, featuredAt])
  @@map("community_works")
}

model CommunityReport {
  id             String                @id
  workId         String                @map("work_id")
  reporterUserId String                @map("reporter_user_id")
  reason         String
  details        String?
  status         CommunityReportStatus @default(open)
  reviewerUserId String?               @map("reviewer_user_id")
  reviewedAt     DateTime?             @map("reviewed_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  work           CommunityWork         @relation(fields: [workId], references: [id])
  reporter       User                  @relation("CommunityReportsMade", fields: [reporterUserId], references: [id])
  reviewer       User?                 @relation("CommunityReportsReviewed", fields: [reviewerUserId], references: [id])

  @@index([workId, status])
  @@index([reporterUserId, createdAt])
  @@index([reviewerUserId])
  @@map("community_reports")
}

model CommunityWorkLike {
  id        String        @id
  workId    String        @map("work_id")
  userId    String        @map("user_id")
  createdAt DateTime      @default(now()) @map("created_at")
  work      CommunityWork @relation(fields: [workId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@unique([workId, userId])
  @@index([userId, createdAt])
  @@map("community_work_likes")
}

model CommunityWorkFavorite {
  id        String        @id
  workId    String        @map("work_id")
  userId    String        @map("user_id")
  createdAt DateTime      @default(now()) @map("created_at")
  work      CommunityWork @relation(fields: [workId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@unique([workId, userId])
  @@index([userId, createdAt])
  @@map("community_work_favorites")
}

// === Workbench (Phase B Cut 1) =================================
// docs/superpowers/plans/2026-05-06-workbench-server-sync.md
// 三件套：项目 / 会话 / 版本节点，IndexedDB 升级为 server-first + offline cache。
// BranchMeta（customLabel / isPinned / isArchived / lastReadAt）从
// IndexedDB 搬到 CreativeSession 表（决议 2026-05-06：用户拍板搬全 4 字段）。

model WorkbenchProject {
  id              String            @id
  userId          String            @map("user_id")
  title           String
  sortOrder       Int               @default(0) @map("sort_order")
  collapsed       Boolean           @default(false)
  activeSessionId String?           @map("active_session_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  user            User              @relation(fields: [userId], references: [id])
  sessions        CreativeSession[]
  versionNodes    VersionNode[]
  imageTasks      ImageTask[]

  @@index([userId, sortOrder])
  @@index([userId, updatedAt])
  @@index([userId, deletedAt])
  @@map("workbench_projects")
}

model CreativeSession {
  id                      String           @id
  projectId               String           @map("project_id")
  title                   String
  forkParentVersionNodeId String?          @map("fork_parent_version_node_id")
  activeVersionNodeId     String?          @map("active_version_node_id")
  customLabel             String?          @map("custom_label")
  isPinned                Boolean          @default(false) @map("is_pinned")
  isArchived              Boolean          @default(false) @map("is_archived")
  lastReadAt              DateTime?        @map("last_read_at")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")
  deletedAt               DateTime?        @map("deleted_at")
  project                 WorkbenchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionNodes            VersionNode[]
  imageTasks              ImageTask[]

  @@index([projectId, updatedAt])
  @@index([projectId, isPinned, updatedAt])
  @@index([projectId, deletedAt])
  @@map("creative_sessions")
}

model VersionNode {
  id                  String            @id
  projectId           String            @map("project_id")
  sessionId           String            @map("session_id")
  parentVersionNodeId String?           @map("parent_version_node_id")
  promptSnapshot      String            @map("prompt_snapshot")
  paramsSnapshot      Json              @map("params_snapshot")
  sourceAssetIds      Json              @map("source_asset_ids")
  outputAssetIds      Json              @map("output_asset_ids")
  boardDocumentId     String?           @map("board_document_id")
  boardSnapshot       Json?             @map("board_snapshot")
  boardExportAssetId  String?           @map("board_export_asset_id")
  branchLabel         String?           @map("branch_label")
  status              VersionNodeStatus
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  deletedAt           DateTime?         @map("deleted_at")
  project             WorkbenchProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session             CreativeSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parent              VersionNode?      @relation("VersionParent", fields: [parentVersionNodeId], references: [id])
  children            VersionNode[]     @relation("VersionParent")
  task                ImageTask?        @relation("VersionNodeTask")

  @@index([sessionId, createdAt])
  @@index([projectId, createdAt])
  @@index([sessionId, updatedAt])
  @@index([projectId, updatedAt])
  @@index([projectId, deletedAt])
  @@index([parentVersionNodeId])
  @@map("version_nodes")
}

model WorkbenchSyncMutation {
  id               String   @id
  userId           String   @map("user_id")
  clientMutationId String   @map("client_mutation_id")
  operation        String
  targetType       String   @map("target_type")
  targetId         String   @map("target_id")
  result           Json
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id])

  @@unique([userId, clientMutationId])
  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@map("workbench_sync_mutations")
}
